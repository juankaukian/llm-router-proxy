# ===== Gateway =====
PORT=8080
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_SMALL_MODEL=gpt-4o-mini
OPENAI_MID_MODEL=gpt-4.1-mini
OPENAI_BIG_MODEL=gpt-4.1

# Optional Ollama for llm.small (local/private addresses only)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:latest

# Optional hardening
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
MAX_BODY_BYTES=65536
MAX_MESSAGES=40
MAX_CONTENT_CHARS=8000
MAX_REQUEST_CHARS=32000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_SSE_MAX=20
MAX_DIAG_CLIENTS=50
MAX_CHAT_STREAM_CLIENTS=100
MAX_SESSION_KEYS=500
FETCH_TIMEOUT_MS=8000
LOG_TRACE_USAGE=false
MAX_OUTPUT_TOKENS_SMALL=350
MAX_OUTPUT_TOKENS_MID=700
MAX_OUTPUT_TOKENS_BIG=1400
PRICING_CONFIG_DIR=/app
MAX_INPUT_TOKENS_TOOL=8000
MAX_INPUT_TOKENS_MATH=12000
MAX_INPUT_TOKENS_MID=24000
MAX_INPUT_TOKENS_BIG=64000
COMPACT_KEEP_LAST_TURNS=6
COMPACT_MIN_SAVINGS_TOKENS=1000
COMPACTOR_PROVIDER=ollama
COMPACTOR_MODEL=llama3:latest
COMPACTOR_BASE_URL=http://host.docker.internal:11434
COMPACTOR_OUTPUT_TOKENS_EST=600
COMPACTOR_TIMEOUT_MS=20000

# Optional API key (if set, clients must send x-api-key or ?api_key=...)
GATEWAY_API_KEY=

# ===== Web (build/runtime) =====
VITE_API_BASE_URL=http://gateway:8080
VITE_GATEWAY_API_KEY=
