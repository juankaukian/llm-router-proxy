# =========================
# Secrets / local env
# =========================
.env
.env.*
*.env
!.env.example

# =========================
# Node / pnpm (monorepo)
# =========================
**/node_modules/
**/.pnpm-store/
**/.npm/
**/.yarn/
**/.cache/

# Keep lockfiles committed for reproducibility
!pnpm-lock.yaml
!**/pnpm-lock.yaml

# =========================
# Build / test artifacts
# =========================
**/dist/
**/build/
**/coverage/
**/.nyc_output/
**/.vite/
**/*.tsbuildinfo
**/.eslintcache

# Evaluation outputs
gateway/eval/report.json

# =========================
# Logs / runtime junk
# =========================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.pid.lock

# =========================
# Docker / compose local overrides
# =========================
docker-compose.override.yml
*.local.yml
*.local.yaml
**/.docker/

# =========================
# OS / editor
# =========================
.DS_Store
**/.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# =========================
# Keep required committed config
# =========================
!gateway/config/pricing.json
